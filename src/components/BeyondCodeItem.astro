---
/**
 * BeyondCodeItem, comic timeline entry.
 * Dark text on paper (no more washed-out ink-300/accent-300 on cream).
 * Timeline is a thick black rule with a yellow diamond marker.
 */
import type { Role } from '~/config';

interface Props {
  item: Role;
  index?: number;
}
const { item, index = 0 } = Astro.props;
const stagger = Math.min(Math.max(index, 1), 6);
---

<article class={`relative pl-8 pb-10 border-l-3 border-ink-900 last:border-transparent anim-in anim-stagger-${stagger}`}>
  <!-- Yellow diamond node, black border -->
  <span
    class="absolute -left-[9px] top-2 w-4 h-4 bg-zap-400 border-3 border-ink-900"
    style="transform: rotate(45deg);"
    aria-hidden="true"
  ></span>

  <span class="eyebrow mb-0">{item.date}</span>
  <h3 class="font-display text-2xl md:text-3xl text-ink-900 mt-1 mb-0.5 leading-snug tracking-wide">
    {item.role}
  </h3>
  <p class="font-heavy uppercase text-pow-600 text-sm tracking-wider mb-3">{item.org}</p>
  <p class="text-ink-800 text-sm leading-relaxed max-w-3xl">{item.description}</p>

  {
    item.highlights && (
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {item.highlights.map((h) => <li class="tag-domain">{h}</li>)}
      </ul>
    )
  }
</article>
