---
import { config } from '~/config';
---

<section class="relative overflow-hidden">
  <div class="dot-grid absolute inset-0 opacity-50" aria-hidden="true"></div>
  <div class="container-wide relative z-10 pt-24 pb-20 md:pt-32 md:pb-28">

    <div class="grid lg:grid-cols-[minmax(0,1fr)_auto] gap-10 lg:gap-14 items-start">
      <!-- Text column -->
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-5 mb-4">
          <!-- Avatar: visible only on small screens so mobile users still see it near the headline -->
          <img
            src="/assets/images/saketh.jpg"
            alt={`${config.name.formal} portrait`}
            width="72"
            height="72"
            loading="eager"
            decoding="async"
            class="lg:hidden w-16 h-16 md:w-20 md:h-20 rounded-full object-cover ring-2 ring-accent-500/50 shadow-lg shadow-accent-500/10"
          />
          <p class="eyebrow anim-in mb-0">Hi, I'm {config.name.first}</p>
        </div>

        <h1 class="anim-in anim-stagger-1 text-4xl md:text-6xl lg:text-7xl font-semibold tracking-tight leading-[1.05]">
          <span class="block">I build at the intersection of</span>
          <span class="block">
            <span class="relative inline-block">
              <span
                class="bg-gradient-to-r from-accent-300 via-accent-400 to-accent-500 bg-clip-text text-transparent bg-[length:200%_100%] animate-[hero-gradient_6s_ease-in-out_infinite]"
              >
                theory, systems, and math
              </span>
            </span>.
          </span>
        </h1>

        <p class="anim-in anim-stagger-2 mt-6 max-w-3xl text-lg md:text-xl text-ink-300 leading-relaxed">
          Computer Science at the Department of Computer Science and Technology,
          University of Cambridge, based at Churchill College, University of
          Cambridge.
        </p>

        <div class="anim-in anim-stagger-3 mt-8 flex flex-wrap gap-3">
          <a href="/portfolio" class="btn-primary">
            See my work
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
          <a href="/research" class="btn-ghost">Research</a>
          <a href={config.links.github} target="_blank" rel="noopener noreferrer" class="btn-ghost">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.93c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.38-3.88-1.38-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.27-5.23-5.67 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18a10.93 10.93 0 0 1 5.73 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.76.11 3.05.73.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.38-5.25 5.66.41.35.77 1.05.77 2.12v3.14c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Portrait column (desktop) -->
      <div class="anim-in anim-stagger-2 hidden lg:block">
        <div class="relative">
          <div class="absolute -inset-3 bg-gradient-to-br from-accent-500/20 via-accent-500/5 to-transparent rounded-2xl blur-xl" aria-hidden="true"></div>
          <img
            src="/assets/images/saketh.jpg"
            alt={`${config.name.formal} portrait`}
            width="320"
            height="320"
            loading="eager"
            decoding="async"
            class="relative w-[260px] xl:w-[320px] h-[260px] xl:h-[320px] rounded-2xl object-cover ring-1 ring-accent-500/30 shadow-2xl shadow-accent-500/10"
          />
        </div>
      </div>
    </div>

    {
      config.stats && (
        <dl class="anim-in anim-stagger-4 mt-16 grid sm:grid-cols-2 gap-6 text-sm max-w-3xl">
          {config.stats.map((s) => (
            <div class="border-l-2 border-accent-500/50 pl-4">
              <dt class="font-mono text-accent-300 text-xs tracking-wide uppercase">{s.label}</dt>
              <dd class="mt-1 text-ink-200 leading-snug">{s.detail}</dd>
            </div>
          ))}
        </dl>
      )
    }

    <div class="anim-in anim-stagger-5 mt-8">
      <a href="/about" class="btn-ghost">
        About me
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>
