---
// Comic nav, strip of stamped panels. Each link is a tilted tag with a hard
// black border. Active page gets yellow fill + a small red "!" dot.
import { config } from '~/config';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};

// Stable-looking per-link rotations so the strip feels hand-placed instead of
// mathematically arranged. Index-based so the same link always gets the same
// angle run to run.
const tilts = [-1.6, 0.9, -0.7, 1.3, -1.1, 0.6, -1.4];
---

<nav
  class="sticky top-0 z-40 w-full border-b-3 border-ink-900 bg-paper"
  style="box-shadow: 0 6px 0 0 #000;"
>
  <div class="container-wide flex items-center justify-between py-4">
    <!-- Monogram stamp -->
    <a
      href="/"
      class="inline-flex items-center gap-2 group"
      aria-label="Home"
    >
      <span
        class="inline-block w-10 h-10 bg-pow-500 text-paper font-display text-xl leading-[2.5rem] text-center border-3 border-ink-900 shadow-comic-sm"
        style="transform: rotate(-4deg);"
      >PR</span>
      <span class="font-heavy text-ink-900 tracking-tight text-lg hidden sm:inline">
        {config.name.formal}
      </span>
    </a>

    <!-- Desktop nav: stamps -->
    <ul class="hidden md:flex items-center gap-2">
      {
        config.nav.map((item, i) => {
          const active = isActive(item.href);
          const tilt = tilts[i % tilts.length];
          return (
            <li style={`transform: rotate(${tilt}deg);`}>
              <a
                href={item.href}
                class:list={[
                  'relative inline-flex items-center px-3 py-1 border-3 border-ink-900 font-heavy uppercase text-xs tracking-[0.16em] shadow-comic-sm transition-transform duration-75',
                  active ? 'bg-zap-400 text-ink-900' : 'bg-paper text-ink-900 hover:bg-zap-200',
                ]}
                style="will-change: transform;"
                onmouseover="this.style.transform='translate(-1px,-1px)'"
                onmouseout="this.style.transform=''"
              >
                {item.label}
                {active && (
                  <span
                    class="ml-2 inline-block w-2 h-2 bg-pow-500 rounded-full border border-ink-900"
                    aria-hidden="true"
                  />
                )}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden w-10 h-10 bg-zap-400 border-3 border-ink-900 shadow-comic-sm font-display text-ink-900"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      ≡
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="md:hidden hidden border-t-3 border-ink-900 bg-paper">
    <ul class="container-wide py-3 flex flex-col gap-2">
      {
        config.nav.map((item) => {
          const active = isActive(item.href);
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block px-4 py-2 border-3 border-ink-900 font-heavy uppercase text-sm tracking-wider',
                  active ? 'bg-zap-400' : 'bg-paper',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>

<script>
  // Mobile menu toggle, tiny, re-runs after Astro view-swap.
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', () => {
      const wasHidden = menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', wasHidden.toString());
    });
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
