---
/**
 * ResearchCard, comic "scroll" version.
 *
 * Dark text on paper. Status chips ("coming soon" / "IP protected") are now
 * comic stamps. No more washed-out ink-300/ink-400 on a cream background.
 */
import type { Paper } from '~/config';

interface Props {
  paper: Paper;
  index?: number;
}
const { paper, index = 0 } = Astro.props;
const stagger = Math.min(Math.max(index, 1), 6);
const href = `/research/${paper.slug}`;

const tilt = (index % 2 === 0 ? -0.6 : 0.8);
---

<article
  class={`relative bg-paper border-3 border-ink-900 shadow-comic p-5 flex flex-col h-full anim-in anim-stagger-${stagger}`}
  style={`transform: rotate(${tilt}deg);`}
>
  <div class="flex items-start justify-between gap-3 mb-2">
    <span class="eyebrow mb-0">{paper.date}</span>
    {paper.ipProtected ? (
      <span
        class="inline-block bg-pow-500 text-paper font-display text-xs tracking-wider px-2 py-1 border-3 border-ink-900 whitespace-nowrap shadow-comic-sm"
        style="transform: rotate(5deg);"
      >
        🔒 SEALED SCROLL
      </span>
    ) : !paper.fullPaperAvailable ? (
      <span
        class="inline-block bg-zap-400 text-ink-900 font-display text-xs tracking-wider px-2 py-1 border-3 border-ink-900 whitespace-nowrap shadow-comic-sm"
        style="transform: rotate(-6deg);"
      >
        ⚡ SCROLL INCOMING!
      </span>
    ) : null}
  </div>

  <h3 class="font-display text-2xl md:text-3xl leading-tight text-ink-900 mb-2 mt-1">
    <a href={href} class="hover:text-pow-600 transition-colors">{paper.title}</a>
  </h3>

  <p class="font-heavy uppercase text-xs tracking-wider text-pow-600 mb-3">
    {paper.authors} · <span class="text-ink-700 normal-case">{paper.venue}</span>
  </p>

  <p class="text-ink-800 text-sm leading-relaxed mb-4 line-clamp-4">
    {paper.abstract}
  </p>

  <div class="flex flex-wrap gap-1.5 mb-4">
    {paper.tags.map((t) => <span class="tag-domain">{t}</span>)}
  </div>

  <div class="pt-3 mt-auto border-t-3 border-ink-900">
    <a href={href} class="btn-primary text-xs">
      Read the scroll
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
    </a>
  </div>
</article>
