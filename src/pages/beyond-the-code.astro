---
/**
 * Beyond the Code, ACHIEVEMENTS HALL.
 *
 * Concept: a trophy room. Each role/service item is a display-case "trophy"
 * tile with a rarity-graded plaque. There's a total trophy count at the top,
 * a little "latest unlock" highlight for the most recent role, and the full
 * trophy wall underneath. Content comes from roles[] in config.ts.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { roles } from '~/config';

// Pick a rarity per role. Based on scope/duration/role-type. This is a
// one-off manual mapping because the config entries don't carry a "rarity"
// field, and it's more honest to hand-tune these than infer on a heuristic.
const rarityBySlug: Record<string, 'legendary' | 'epic' | 'rare' | 'uncommon'> = {
  'Undergraduate Academic Rep · Junior Member, Faculty Board of CS': 'legendary',
  'Founder · Student Panel': 'epic',
  'Founder & Lead · Advanced Java Club': 'rare',
  'Teaching Assistant': 'uncommon',
  'Founder · Peer Tutoring Initiative': 'rare',
};

function rarityOf(role: string) {
  return rarityBySlug[role] ?? 'uncommon';
}

function rarityClass(r: string) {
  return r === 'legendary' ? 'bg-zap-400 text-ink-900' :
         r === 'epic'      ? 'bg-ink-900 text-paper' :
         r === 'rare'      ? 'bg-pow-500 text-paper' :
         r === 'uncommon'  ? 'bg-zap-200 text-ink-900' :
                             'bg-paper text-ink-900';
}

function rarityIcon(r: string) {
  return r === 'legendary' ? '★' :
         r === 'epic'      ? '◈' :
         r === 'rare'      ? '◆' :
                             '●';
}

// Sort: "present" (current) roles first, then reverse chronological by the
// start year parsed out of role.date. Gentle heuristic; the display order
// mostly tracks the order already in config.ts.
function startYear(s: string): number {
  const m = s.match(/\d{4}/);
  return m ? parseInt(m[0], 10) : 0;
}

const sorted = [...roles].sort((a, b) => {
  const aCurrent = /present/i.test(a.date) ? 1 : 0;
  const bCurrent = /present/i.test(b.date) ? 1 : 0;
  if (aCurrent !== bCurrent) return bCurrent - aCurrent;
  return startYear(b.date) - startYear(a.date);
});

const latest = sorted[0];
const rest = sorted.slice(1);
---

<BaseLayout
  title="Beyond the Code"
  description="Leadership, teaching, and service. Cambridge academic rep, BASIS Student Panel founder, tutor, TA."
>
  <!-- ── HALL BANNER ──────────────────────────────────────────────────── -->
  <section class="container-wide pt-12 pb-4">
    <div class="flex items-end justify-between flex-wrap gap-3 mb-2">
      <div>
        <span class="eyebrow">Achievements hall</span>
        <h1 class="font-display text-5xl md:text-7xl leading-[0.9] text-ink-900">
          Trophy room.
        </h1>
      </div>
      <span class="font-ui text-xs text-ink-700 tracking-[0.25em]">
        TROPHIES · {String(sorted.length).padStart(2, '0')} / {String(sorted.length).padStart(2, '0')}
      </span>
    </div>

    <p class="text-ink-800 leading-relaxed max-w-2xl">
      The work I care about outside the terminal. Representing my cohort,
      running clubs, tutoring peers, and raising money for causes that
      matter. Each plaque is rarity-graded for vibes, not for weight class.
    </p>

    <div class="divider-jagged mt-6"></div>
  </section>

  <!-- ── LATEST UNLOCK (highlighted plaque) ───────────────────────────── -->
  {latest && (
    <section class="container-wide pb-8">
      <div class="flex items-center gap-3 mb-5">
        <span
          class="inline-block bg-pow-500 text-paper font-display text-lg px-3 py-1 border-3 border-ink-900 shadow-comic-sm"
          style="transform: rotate(-3deg);"
        >
          ★ LATEST UNLOCK
        </span>
        <span class="font-ui text-[0.7rem] text-ink-700 tracking-[0.25em]">
          MOST RECENT TROPHY
        </span>
      </div>

      <article
        class="relative border-3 border-ink-900 shadow-comic p-6 bg-paper"
        style="transform: rotate(-0.4deg);"
      >
        <!-- Big plaque stamp -->
        <span
          class={`absolute -top-4 -right-3 inline-block font-display text-base px-3 py-1 border-3 border-ink-900 shadow-comic-sm ${rarityClass(rarityOf(latest.role))}`}
          style="transform: rotate(6deg);"
        >
          {rarityIcon(rarityOf(latest.role))} {rarityOf(latest.role).toUpperCase()}
        </span>

        <p class="font-ui text-[0.7rem] tracking-[0.25em] text-ink-700 mb-1">
          {latest.date}
        </p>
        <h2 class="font-display text-3xl md:text-4xl leading-tight text-ink-900 mb-1">
          {latest.role}
        </h2>
        <p class="font-heavy uppercase text-sm tracking-wider text-pow-600 mb-4">
          {latest.org}
        </p>
        <p class="text-ink-800 leading-relaxed max-w-3xl">
          {latest.description}
        </p>
      </article>
    </section>
  )}

  <!-- ── TROPHY WALL ──────────────────────────────────────────────────── -->
  {rest.length > 0 && (
    <section class="container-wide pb-24">
      <div class="flex items-center gap-3 mb-5 mt-6">
        <span
          class="inline-block bg-zap-400 text-ink-900 font-display text-lg px-3 py-1 border-3 border-ink-900 shadow-comic-sm"
          style="transform: rotate(1.5deg);"
        >
          ◈ TROPHY WALL
        </span>
        <span class="font-ui text-[0.7rem] text-ink-700 tracking-[0.25em]">
          RECLAIMED PLAQUES
        </span>
      </div>

      <ul class="grid md:grid-cols-2 gap-6">
        {rest.map((r, i) => {
          const rar = rarityOf(r.role);
          const tilt = (i % 2 === 0 ? -0.6 : 0.7);
          return (
            <li
              class={`relative border-3 border-ink-900 shadow-comic p-5 bg-paper flex flex-col h-full anim-in anim-stagger-${Math.min(i + 1, 6)}`}
              style={`transform: rotate(${tilt}deg);`}
            >
              <!-- Rarity plaque corner -->
              <span
                class={`absolute -top-3 -right-3 inline-block font-display text-sm px-2 py-1 border-3 border-ink-900 shadow-comic-sm ${rarityClass(rar)}`}
                style="transform: rotate(6deg);"
              >
                {rarityIcon(rar)} {rar.toUpperCase()}
              </span>

              <p class="font-ui text-[0.65rem] tracking-[0.25em] text-ink-700 mb-1">
                {r.date}
              </p>
              <h3 class="font-display text-xl md:text-2xl leading-tight text-ink-900 mb-1">
                {r.role}
              </h3>
              <p class="font-heavy uppercase text-xs tracking-wider text-pow-600 mb-3">
                {r.org}
              </p>
              <p class="text-ink-800 text-sm leading-relaxed">{r.description}</p>

              {r.highlights && (
                <ul class="mt-3 flex flex-wrap gap-1.5">
                  {r.highlights.map((h) => <li class="tag-domain">{h}</li>)}
                </ul>
              )}
            </li>
          );
        })}
      </ul>

      <p class="mt-8 font-ui text-[0.7rem] text-ink-700 tracking-[0.25em]">
        TIP · TROPHIES DON'T EXPIRE. THE SHELF JUST GETS LONGER.
      </p>
    </section>
  )}
</BaseLayout>
