---
/**
 * 404 GAME OVER screen.
 *
 * Concept: the classic arcade "GAME OVER" / "CONTINUE?" moment. Big pow-red
 * header, blinking prompt, scoreboard with a fake score/stage, and an option
 * to insert another coin (go home). Mostly vibes, a bit of a joke.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { config } from '~/config';
---

<BaseLayout title="Game over" description="Page not found">
  <!-- CRT-ish full-bleed section. scanlines + halftone come from base css -->
  <section
    class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-ink-900 text-paper"
  >
    <!-- Scanlines overlay (cosmetic). Pointer-events none so links still work. -->
    <div class="scanlines absolute inset-0 pointer-events-none opacity-30"></div>

    <!-- Corner stage/score readouts, like an arcade HUD -->
    <div class="absolute top-5 left-5 font-ui text-[0.7rem] tracking-[0.25em] text-zap-400">
      STAGE · 404
    </div>
    <div class="absolute top-5 right-5 font-ui text-[0.7rem] tracking-[0.25em] text-zap-400">
      PLAYER · {config.name.first.toUpperCase()}
    </div>
    <div class="absolute bottom-5 left-5 font-ui text-[0.7rem] tracking-[0.25em] text-ink-500">
      CREDITS · 00
    </div>
    <div class="absolute bottom-5 right-5 font-ui text-[0.7rem] tracking-[0.25em] text-ink-500">
      HIGH SCORE · 999999
    </div>

    <div class="relative text-center px-6 max-w-[680px]">
      <!-- Big stamped title -->
      <p class="font-ui text-xs tracking-[0.3em] text-zap-400 mb-3">YOU FOUND A WILD 404</p>
      <h1
        class="font-display text-pow-500 leading-[0.85] mb-2"
        style="font-size: clamp(4rem, 14vw, 9rem); text-shadow: 6px 6px 0 #050504;"
      >
        GAME<br />OVER
      </h1>

      <p class="mt-6 font-heavy uppercase text-sm tracking-widest text-paper/90">
        This page isn't on the map.
      </p>

      <!-- Blinking "CONTINUE?" prompt -->
      <p class="mt-8 font-display text-2xl md:text-3xl text-zap-400 blink-prompt">
        CONTINUE? &gt; YES / <span class="text-ink-500">NO</span>
      </p>

      <p class="mt-2 font-ui text-[0.7rem] tracking-[0.25em] text-ink-400">
        INSERT COIN TO TRY AGAIN
      </p>

      <!-- CTA row -->
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <a
          href="/"
          class="btn bg-zap-400 text-ink-900 font-display text-lg px-5 py-2 border-3 border-paper shadow-comic-sm hover:translate-x-[2px] hover:translate-y-[2px] transition-transform"
        >
          ▶ RESPAWN AT HOME
        </a>
        <a
          href="/portfolio"
          class="btn bg-transparent text-paper border-3 border-paper font-heavy uppercase tracking-wider px-4 py-2 hover:bg-paper hover:text-ink-900 transition-colors"
        >
          Browse the loot instead
        </a>
      </div>

      <!-- Flavour -->
      <p class="mt-10 text-ink-300 text-sm leading-relaxed max-w-md mx-auto">
        Hi, I'm {config.name.first}. Whatever you were trying to reach, it
        isn't here. The rest of the site is though, and it's much less
        apologetic.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Blinking prompt, classic arcade cadence.
     Respect reduced-motion: freeze it visible instead of strobing. */
  .blink-prompt {
    animation: blinkPrompt 1.1s steps(2, end) infinite;
  }
  @keyframes blinkPrompt {
    0%, 60% { opacity: 1; }
    61%, 100% { opacity: 0.25; }
  }
  @media (prefers-reduced-motion: reduce) {
    .blink-prompt { animation: none; opacity: 1; }
  }
</style>
