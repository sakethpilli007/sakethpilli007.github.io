---
/**
 * Martial Arts, FIGHTER SELECT screen.
 *
 * Concept: the "CHOOSE YOUR FIGHTER" menu. Three roster entries, one active
 * (highlighted with "★ CURRENT MAIN"), two retired (greyed 'LOCKED' style
 * card but still fully legible). Each card shows the dojo portrait slot, the
 * style, rank, and trainer, framed as STR / DEF / TEC stat bars.
 *
 * Content is unchanged from the timeline version, just restructured around
 * the fighter-select metaphor so the page isn't yet another vertical list.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';

type Fighter = {
  id: string;
  years: string;
  dojo: string;
  style: string;
  rank: string;
  under: string;
  status: 'past' | 'current';
  // Stat bars, 0-100. Not a real measurement, a vibe-based stamp on each era.
  stats: { STR: number; DEF: number; TEC: number };
  // Dojo crest image (served from /public/assets/logos).
  logo: string;
  logoAlt: string;
};

const fighters: Fighter[] = [
  // NB: each roster entry's stats deliberately sum to 250. Modern Tang Soo
  // Do is the STR spec (most offence-heavy), Traditional Tang Soo Do is the
  // DEF spec (highest guard), Shotokan is the TEC spec (most technique).
  {
    id: 'p01',
    years: '2014 – 2018 · 4 years',
    dojo: 'Peak Performance Martial Arts',
    style: 'Modern Tang Soo Do',
    rank: 'Cho Dan Bo',
    under: 'Master Gary Schill',
    status: 'past',
    stats: { STR: 100, DEF: 80, TEC: 70 },
    logo: '/assets/logos/peak-performance.png',
    logoAlt: 'Peak Performance Martial Arts crest',
  },
  {
    id: 'p02',
    years: '2019 – 2025 · 6 years',
    dojo: 'The First Tang Soo Do of Fremont',
    style: 'Traditional Tang Soo Do',
    rank: '2nd Gup (Red)',
    under: 'Master David Bell',
    status: 'past',
    stats: { STR: 70, DEF: 95, TEC: 85 },
    logo: '/assets/logos/ftsd.png',
    logoAlt: 'First Tang Soo Do of Fremont · Healing Arts Center crest',
  },
  {
    id: 'c01',
    years: '2025 – present',
    dojo: 'Cambridge University Karate Club',
    style: 'Shotokan Karate',
    rank: '3rd Kyu',
    under: '',
    status: 'current',
    stats: { STR: 65, DEF: 85, TEC: 100 },
    logo: '/assets/logos/cukc.svg',
    logoAlt: 'Cambridge University Karate Club crest',
  },
];

// Sort current first, then past in reverse chronological (so the newest past
// era sits right under the active roster slot).
const roster = [
  ...fighters.filter((f) => f.status === 'current'),
  ...fighters.filter((f) => f.status === 'past').reverse(),
];
---

<BaseLayout
  title="Martial Arts"
  description="A decade of martial arts. Modern and Traditional Tang Soo Do in California, now Shotokan Karate at Cambridge."
>
  <!-- ── FIGHTER SELECT BANNER ────────────────────────────────────────── -->
  <section class="container-wide pt-12 pb-4">
    <div class="flex items-end justify-between flex-wrap gap-3 mb-2">
      <div>
        <span class="eyebrow">Fighter select</span>
        <h1 class="font-display text-5xl md:text-7xl leading-[0.9] text-ink-900">
          Choose your stance.
        </h1>
      </div>
      <span class="font-ui text-xs text-ink-700 tracking-[0.25em]">
        ROSTER · 03 / 03
      </span>
    </div>

    <p class="text-ink-800 leading-relaxed max-w-2xl">
      A decade across three styles. The discipline has taught me more about
      focus, humility, and steady practice than anything else, and I still
      show up to the dojo a couple of times a week.
    </p>

    <div class="divider-jagged mt-6"></div>
  </section>

  <!-- ── ROSTER GRID ──────────────────────────────────────────────────── -->
  <section class="container-wide pb-24">
    <ul class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {roster.map((f, i) => {
        const tilt = (i % 2 === 0 ? -1 : 1) * (0.6 + (i % 3) * 0.3);
        const isCurrent = f.status === 'current';
        return (
          <li
            class={`relative border-3 border-ink-900 shadow-comic p-5 flex flex-col h-full anim-in anim-stagger-${Math.min(i + 1, 6)} ${
              isCurrent ? 'bg-paper' : 'bg-zap-200'
            }`}
            style={`transform: rotate(${tilt}deg);`}
          >
            <!-- Slot stamp -->
            <span
              class="absolute -top-3 -left-3 inline-block bg-ink-900 text-paper font-ui text-[0.6rem] tracking-[0.25em] px-2 py-1 border-3 border-ink-900"
              style="transform: rotate(-6deg);"
            >
              SLOT · {f.id.toUpperCase()}
            </span>

            {isCurrent && (
              <span
                class="absolute -top-4 -right-3 inline-block bg-pow-500 text-paper font-display text-base px-3 py-1 border-3 border-ink-900 shadow-comic-sm"
                style="transform: rotate(8deg);"
              >
                ★ CURRENT MAIN
              </span>
            )}

            <!-- Dojo crest panel. Real logo, framed like a fighter portrait.
                 items-start + top padding lifts the crest above the bottom-right
                 style label so nothing overlaps the text. -->
            <div
              class={`mt-2 mb-3 aspect-[4/3] border-3 border-ink-900 flex items-start justify-center relative overflow-hidden pt-3 pb-10 ${
                isCurrent ? 'bg-zap-400' : 'bg-paper'
              }`}
            >
              <img
                src={f.logo}
                alt={f.logoAlt}
                loading="lazy"
                decoding="async"
                class="max-h-full max-w-[70%] w-auto h-auto object-contain select-none pointer-events-none"
              />
              <span
                class="absolute bottom-2 right-2 font-ui text-[0.6rem] text-ink-900 tracking-[0.25em] bg-paper/80 px-1.5 py-0.5 border-2 border-ink-900"
              >
                {f.style.toUpperCase()}
              </span>
            </div>

            <p class="font-ui text-[0.65rem] tracking-[0.25em] text-ink-700 mb-1">
              {f.years}
            </p>
            <h3 class="font-display text-2xl leading-tight text-ink-900 mb-3">
              {f.dojo}
            </h3>

            <!-- Stat bars -->
            <dl class="space-y-1.5 mb-4">
              {(['STR', 'DEF', 'TEC'] as const).map((k) => (
                <div class="flex items-center gap-2">
                  <dt class="font-display text-sm leading-none text-ink-900 w-10">{k}</dt>
                  <dd class="flex-1 relative h-3 border-2 border-ink-900 bg-paper">
                    <span
                      class="absolute top-0 left-0 bottom-0 bg-pow-500"
                      style={`width: ${f.stats[k]}%`}
                    ></span>
                  </dd>
                  <span class="font-mono text-[0.65rem] text-ink-900 w-8 text-right">
                    {f.stats[k]}
                  </span>
                </div>
              ))}
            </dl>

            <!-- Card info line: rank + trainer -->
            <div class="pt-3 mt-auto border-t-3 border-ink-900 text-sm grid gap-1">
              <div class="flex justify-between gap-2">
                <span class="font-ui text-[0.65rem] tracking-widest uppercase text-ink-700">Rank</span>
                <span class="font-heavy text-ink-900">{f.rank}</span>
              </div>
              {f.under && (
                <div class="flex justify-between gap-2">
                  <span class="font-ui text-[0.65rem] tracking-widest uppercase text-ink-700">Trainer</span>
                  <span class="font-heavy text-ink-900 text-right">{f.under}</span>
                </div>
              )}
            </div>
          </li>
        );
      })}
    </ul>

  </section>
</BaseLayout>
